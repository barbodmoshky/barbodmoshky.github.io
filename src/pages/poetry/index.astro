---
const SITE_TITLE = "اشعار من | باربد مشکی";
const SITE_DESCRIPTION = "بخش اشعار سایت؛ مجموعه‌ای از شعرها و نوشته‌های ادبی در قالب بلاگ.";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Blogcard from "../../components/Blogcard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("poetry")).sort(
  (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="fa">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="page-intro">
        <h1>اشعار من</h1>
        <p>در این بخش می‌توانید شعرهای من را به شکل بلاگ و با توضیحات مختصر بخوانید.</p>
      </section>
      <section class="posts">
        <ul>
          {posts.map((post: any) => (
            <li>
              <Blogcard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                link={`/poetry/${post.id}`}
                heroImage={post.data.heroImage || "/logo.jpg"}
              />
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 960px;
    max-width: 100%;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .page-intro {
    text-align: center;
    margin-bottom: 30px;
  }

  .page-intro h1 {
    margin-bottom: 10px;
    color: #4e342e;
  }

  .page-intro p {
    color: #5d4037;
    line-height: 1.8;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    list-style-type: none;
    margin: 0;
    padding: 0;
  }

  ul li {
    width: calc(50% - 1rem);
  }

  @media (max-width: 720px) {
    ul li {
      width: 100%;
    }
  }
</style>