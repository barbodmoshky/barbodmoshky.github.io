---
import HeaderLink from "./HeaderLink.astro";
---

<header>
  <div class="container">
    <img class="logo" src="/logo.jpg" alt="لوگوی سایت باربد مشکی" />
    <nav>
      <ul>
        <li><HeaderLink href="/">صفحه اصلی</HeaderLink></li>
        <li><HeaderLink href="/about-me">درباره من</HeaderLink></li>
        <li>
          <HeaderLink href="/recommend">آهنگ‌های پیشنهادی</HeaderLink>
        </li>
        <li><HeaderLink href="/blog">وبلاگ</HeaderLink></li>
        <li><HeaderLink href="/poetry">اشعار</HeaderLink></li>
        <li><HeaderLink href="/foreign-music">موسیقی خارجی</HeaderLink></li>
        <li><HeaderLink href="/iranian-pop">پاپ ایرانی</HeaderLink></li>
        <li><HeaderLink href="/biography">زندگی‌نامه</HeaderLink></li>
        <li><HeaderLink href="/gallery">گالری عکس‌ها</HeaderLink></li>
        <li><HeaderLink href="/contact">تماس با من</HeaderLink></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  /* هدر */
  header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 15px 0;
    box-shadow: 0 2px 10px rgba(102, 126, 234, 0.3);
  }

  .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 20px;
    direction: ltr;
    font-family: "B Nazanin", sans-serif;
  }

  .logo {
    width: 75px;
    height: auto;
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: row-reverse;
    gap: 15px;
  }

  nav ul li {
    margin: 0 15px;
  }

  /* استایل برای گوشی */
  @media (max-width: 768px) {
    .container {
      flex-direction: column;
      align-items: center;
    }

    nav ul {
      flex-direction: column;
      gap: 10px;
      text-align: center;
    }

    .logo {
      margin-bottom: 15px;
    }
  }
</style>
