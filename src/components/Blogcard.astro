---
interface Props {
  title: string;
  description: string;
  pubDate: string;
  link: string;
  heroImage: string;
}

const { title, description, pubDate, link, heroImage } = Astro.props;
---

<article class="post">
  <a href={link}>
    <img src={heroImage} alt={title} />
    <h2>{title}</h2>
    <p>{description}</p>
    <time>{new Date(pubDate).toLocaleDateString("fa-IR")}</time>
  </a>
</article>

<style>
  .post {
    background: #fff;
    margin: 20px 0;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
    transition: transform 0.3s, box-shadow 0.3s;
    animation: fadeIn 1.5s ease-in-out;
    border: 1px solid rgba(102, 126, 234, 0.1);
  }
  .post:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 24px rgba(102, 126, 234, 0.25);
    border-color: #667eea;
  }
  .post img {
    width: 50%;
    border-radius: 12px;
    margin-bottom: 1rem;
    border: 2px solid rgba(102, 126, 234, 0.2);
  }
  .post h2 {
    margin: 0;
    font-size: 1.5rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: all 0.3s ease;
  }
  .post p {
    margin: 0.5rem 0;
    color: #666;
  }
  .post time {
    font-size: 0.875rem;
    color: #667eea;
    font-weight: 600;
  }
  .post a {
    text-decoration: none;
    color: inherit;
  }
  .post a:hover h2 {
    opacity: 0.8;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>