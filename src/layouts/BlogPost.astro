---
// filepath: c:\Users\ASUS\Desktop\astro-project\barbodclassicalmusic.github.io\src\layouts\BlogPostLayout.astro
interface Props {
  title: string;
  description: string;
  pubDate?: Date;
  heroImage?: string;
  audioUrl?: string;
  lyrics?: string;
}

const { title, description, pubDate, heroImage, audioUrl, lyrics } = Astro.props;
---

<html lang="fa">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="/src/styles/article-style.css" />
  </head>
  <body>
    <article class="blog-post">
      <header class="blog-header">
        <div class="blog-header-content">
          <h1>{title || "عنوان نامشخص"}</h1>
          <p class="date">
            منتشر شده در: {
              pubDate && !isNaN(Date.parse(pubDate.toDateString()))
                ? new Date(pubDate).toLocaleDateString("fa-IR", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })
                : "تاریخ نامعتبر"
            }
          </p>
        </div>
        <img
          src={heroImage || "/default-image.png"}
          alt={title || "تصویر نامشخص"}
        />
      </header>

      {audioUrl && (
        <section class="audio-section">
          <h2>🎵 گوش‌کردن به آهنگ</h2>
          <audio controls class="audio-player">
            <source src={audioUrl} type="audio/mpeg" />
            مرورگر شما از پخش صوت پشتیبانی نمی‌کند.
          </audio>
        </section>
      )}

      <main class="blog-content">
        <slot />
      </main>

      {lyrics && (
        <section class="lyrics-section">
          <h2>📝 متن آهنگ</h2>
          <div class="lyrics-content">
            {lyrics}
          </div>
        </section>
      )}

      <footer>
        <p>&copy; 2025 تمامی حقوق محفوظ است.</p>
      </footer>
    </article>
  </body>
</html>
